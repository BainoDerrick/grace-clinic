{
    "version": 2,
    "buildCommand": "true",
    "api": {
        "nodeGroup": "default"
    },
    "routes": [
        {
            "src": "/public/(.*)",
            "dest": "/public/$1",
            "headers": {
                "cache-control": "public, max-age=3600"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}